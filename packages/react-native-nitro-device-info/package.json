{
  "name": "react-native-nitro-device-info",
  "version": "1.7.1",
  "description": "Get device info for React Native using Nitro",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./lib/typescript/src/index.d.ts",
      "browser": "./lib/module/index.web.js",
      "default": "./lib/module/index.js"
    },
    "./compat": {
      "source": "./src/compat/index.ts",
      "types": "./lib/typescript/src/compat/index.d.ts",
      "default": "./lib/module/compat/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": "./bin/migrate.js",
  "files": [
    "src",
    "lib",
    "bin",
    "android",
    "ios",
    "cpp",
    "nitrogen",
    "nitro.json",
    "*.podspec",
    "react-native.config.js",
    "app.plugin.js",
    "plugin/build/**",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "prepare": "bob build && yarn build:plugin",
    "build:plugin": "tsc --project plugin/tsconfig.json",
    "nitrogen": "nitrogen",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "clean": "del-cli lib nitrogen/generated android/build ios/build plugin/build"
  },
  "keywords": [
    "react-native",
    "ios",
    "android"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/l2hyunwoo/react-native-nitro-device-info.git"
  },
  "author": "HyunWoo Lee <l2hyunwoo@gmail.com> (https://github.com/l2hyunwoo)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/l2hyunwoo/react-native-nitro-device-info/issues"
  },
  "homepage": "https://github.com/l2hyunwoo/react-native-nitro-device-info#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-nitro-modules": ">=0.35.0 <1.0.0"
  },
  "devDependencies": {
    "@expo/config-plugins": "~56.0.9",
    "@react-native/jest-preset": "0.85.3",
    "@types/jscodeshift": "17.3.0",
    "del-cli": "7.0.0",
    "jest": "29.7.0",
    "jscodeshift": "17.3.0",
    "nitrogen": "0.35.9",
    "react-native-builder-bob": "0.41.0",
    "typescript": "5.9.3"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "custom",
        {
          "script": "nitrogen",
          "clean": "nitrogen/"
        }
      ],
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "create-react-native-library": {
    "languages": "kotlin-swift",
    "type": "nitro-module",
    "version": "0.54.7"
  }
}
