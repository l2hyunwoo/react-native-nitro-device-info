{
  "name": "react-native-nitro-device-info-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for react-native-nitro-device-info",
  "scripts": {
    "showcase": "yarn workspace react-native-nitro-device-info-example",
    "benchmark": "yarn workspace react-native-nitro-device-info-benchmark",
    "integrity-demo": "yarn workspace react-native-nitro-device-integrity-demo",
    "pod:showcase": "cd example/showcase/ios && pod install",
    "pod:benchmark": "cd example/benchmark/ios && pod install",
    "pod:integrity-demo": "cd example/integrity-demo/ios && pod install",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "lint:eslint": "eslint \"**/*.{js,ts,tsx}\"",
    "clean": "del-cli packages/react-native-nitro-device-info/lib packages/react-native-nitro-device-info/nitrogen/generated packages/react-native-nitro-device-info/android/build example/showcase/android/build example/showcase/android/app/build example/showcase/ios/build example/benchmark/android/build example/benchmark/android/app/build example/benchmark/ios/build",
    "prepare": "yarn workspace react-native-nitro-device-info prepare",
    "nitrogen": "yarn workspace react-native-nitro-device-info nitrogen",
    "nitrogen:integrity": "yarn workspace react-native-nitro-device-integrity nitrogen"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/l2hyunwoo/react-native-nitro-device-info.git"
  },
  "author": "HyunWoo Lee <l2hyunwoo@gmail.com> (https://github.com/l2hyunwoo)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/l2hyunwoo/react-native-nitro-device-info/issues"
  },
  "homepage": "https://github.com/l2hyunwoo/react-native-nitro-device-info#readme",
  "devDependencies": {
    "@commitlint/config-conventional": "21.0.2",
    "@eslint/compat": "2.1.0",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "9.39.4",
    "@evilmartians/lefthook": "2.1.9",
    "@react-native/babel-preset": "0.85.3",
    "@react-native/eslint-config": "0.85.3",
    "@types/jest": "29.5.14",
    "@types/react": "19.2.17",
    "commitlint": "21.0.2",
    "del-cli": "7.0.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "jest": "29.7.0",
    "nitrogen": "0.35.9",
    "oxlint": "1.57.0",
    "prettier": "3.8.4",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-builder-bob": "0.41.0",
    "react-native-nitro-modules": "0.35.9",
    "turbo": "2.9.18",
    "typescript": "5.9.3"
  },
  "workspaces": [
    "packages/react-native-nitro-device-info",
    "packages/react-native-nitro-device-integrity",
    "packages/mcp-server",
    "example/showcase",
    "example/benchmark",
    "example/integrity-demo"
  ],
  "resolutions": {
    "ws@^8.18.2": "8.20.1",
    "qs": "6.15.2",
    "ip-address": "10.1.1",
    "minimatch@^9.0.4": "9.0.7",
    "minimatch@^10.0.1": "10.2.3",
    "minimatch@^10.1.1": "10.2.3",
    "picomatch@^4.0.2": "4.0.4",
    "picomatch@^4.0.3": "4.0.4"
  },
  "packageManager": "yarn@3.6.1",
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  }
}
